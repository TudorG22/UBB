#!/usr/bin/bash
set -e

echo "Rulare teste..."

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
COVERAGE_DIR="$SCRIPT_DIR/coverage"

mkdir -p "$COVERAGE_DIR"
rm -f "$COVERAGE_DIR"/*
find "$PROJECT_DIR" \( -name '*.gcda' -o -name '*.gcno' -o -name '*.gcov' \) -delete

cd "$COVERAGE_DIR"

g++ --coverage -Wvla -Wall -Werror -I "$PROJECT_DIR/include" \
    "$PROJECT_DIR/src/domain.cpp" \
    "$PROJECT_DIR/src/validator.cpp" \
    "$PROJECT_DIR/src/repoVector.cpp" \
    "$PROJECT_DIR/src/repoMap.cpp" \
    "$PROJECT_DIR/src/undo.cpp" \
    "$PROJECT_DIR/src/service.cpp" \
    "$SCRIPT_DIR/test_domain_repo_service.cpp" \
    -o "$COVERAGE_DIR/coverage_bin"

"$COVERAGE_DIR/coverage_bin"

gcovr "$PROJECT_DIR" \
    --filter "$PROJECT_DIR/src" \
    --exclude "$PROJECT_DIR/src/ui.cpp" \
    --exclude "$PROJECT_DIR/src/ui_old.cpp" \
    --object-directory "$COVERAGE_DIR" \
    --merge-mode-functions=merge-use-line-min \
    --html-details "$COVERAGE_DIR/coverage.html"

echo "Gata."
