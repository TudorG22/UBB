#!/usr/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

g++ -Wvla -Wall -Werror -I "$PROJECT_DIR/include" \
    "$PROJECT_DIR/src/domain.cpp" \
    "$PROJECT_DIR/src/validator.cpp" \
    "$PROJECT_DIR/src/repo.cpp" \
    "$PROJECT_DIR/src/service.cpp" \
    "$SCRIPT_DIR/test_domain_repo_service.cpp" \
    -o "$SCRIPT_DIR/run_tests_bin"

"$SCRIPT_DIR/run_tests_bin"
